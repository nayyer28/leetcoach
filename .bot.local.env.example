# Local bot tooling configuration (do not commit real values)

# Bot commit author identity (used by scripts/git_bot_commit.sh)
# Use the actual bot name (e.g., "Claude", "Codex", etc.) to identify which assistant made the commit
BOT_GIT_NAME=Code Assist Bot
BOT_GIT_EMAIL=bot@local.invalid

# Default PR base branch (optional convenience for future tooling)
DEFAULT_PR_BASE=main

# GitHub App configuration for scripts/gh_app_token.sh
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/app.private-key.pem
