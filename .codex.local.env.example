# Local Codex tooling configuration (do not commit real values)

# Codex commit author identity (used by scripts/git_codex_commit.sh)
CODEX_GIT_NAME=Codex
CODEX_GIT_EMAIL=codex@local.invalid

# Default PR base branch (optional convenience for future tooling)
DEFAULT_PR_BASE=main

# GitHub App configuration for scripts/gh_app_token.sh
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/app.private-key.pem
